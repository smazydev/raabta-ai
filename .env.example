# ---------------------------------------------------------------------------
# PostgreSQL (required) — same app for Supabase DB, Amazon RDS, Neon, local, etc.
# Use the URI from your host (often "Connection string" / "URI" in the console).
# Switching from Supabase-hosted Postgres to RDS is only changing this value (+ network access).
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Supabase: if `db.<ref>.supabase.co` fails DNS (e.g. ENOTFOUND on IPv4-only networks), use the
# pooler URI from Dashboard → Settings → Database → Transaction pooler (port 6543). Example:
# DATABASE_URL=postgresql://postgres.<project-ref>:YOUR_DB_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require
# URL-encode special characters in the password (@ → %40, # → %23, etc.).

# Optional aliases if your host pre-fills a different name (first match wins):
# POSTGRES_URL=postgresql://...
# SUPABASE_DATABASE_URL=postgresql://postgres.[ref].supabase.co:5432/postgres

# Pool size cap (optional)
# PG_POOL_MAX=20

# If login / DB calls fail with SELF_SIGNED_CERT_IN_CHAIN, set (dev only — weakens TLS verification).
# The pool rewrites sslmode=require → sslmode=no-verify so node-pg does not overwrite relaxed SSL.
# PG_SSL_REJECT_UNAUTHORIZED=false

# Session cookie signing (required in production; min 16 characters)
SESSION_SECRET=change-me-min-16-chars-please

# ---------------------------------------------------------------------------
# OpenAI — never expose to the browser
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
# Optional override (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# AI credit pricing: tokens per 1 billed credit (default 1000). Higher = more usage per credit.
# RAABTA_CREDITS_TOKENS_PER_CREDIT=1000
# TTS credit multiplier (default 1)
# RAABTA_CREDITS_TTS_MULTIPLIER=1

# Chat billing: use OpenAI list $/1M (GPT-5.4 family in lib/billing/openai-provider-rates.ts) × margin → credits
# RAABTA_OPENAI_COST_BASED_BILLING=true
# RAABTA_OPENAI_COST_MARGIN=2
# Retail meter: credits = ceil(provider_usd × margin × RAABTA_RETAIL_CREDITS_PER_USD); align with tenant PAYG credits/$
# RAABTA_RETAIL_CREDITS_PER_USD=5000

# Embeddings for knowledge RAG (default text-embedding-3-small, 1536 dims — matches migration vector(1536))
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OpenAI Speech API — natural TTS for voice demos (server-only)
# Default: gpt-4o-mini-tts + style instructions (more human-like). Fallback: tts-1-hd
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=nova
# OPENAI_TTS_INSTRUCTIONS=Speak clearly like a professional support agent...

# OpenAI Realtime (voice front-desk)
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# OPENAI_REALTIME_VOICE=verse

# Language rollout flags (Urdu is always primary/enabled)
# FEATURE_LANG_SD=false
# FEATURE_LANG_PS=false

# Demo seed password for scripts/seed.ts
# DEMO_SEED_PASSWORD=DemoRaabta123!

# Marketing site URL (login page link)
NEXT_PUBLIC_LANDING_URL=http://localhost:4321

# Dashboard chrome: deployment badge (production | sandbox | development fallback)
# NEXT_PUBLIC_APP_ENV=production

# Hide Sandbox nav (e.g. client chat simulator) in production consoles
# NEXT_PUBLIC_HIDE_DEMO_NAV=true

# Workflow HTTP nodes — optional external bank adapter base URL (no trailing slash).
# If unset, the executor calls the in-app mock at {INTERNAL_APP_URL or NEXT_PUBLIC_APP_URL or VERCEL_URL}/api/mock-adapter
# BANK_ADAPTER_BASE_URL=https://sandbox.bank.example

# Optional Bearer token sent to BANK_ADAPTER_BASE_URL (never expose to the client)
# BANK_ADAPTER_API_KEY=

# Server-side URL of this app when calling the mock adapter from workflow runs (local dev: http://127.0.0.1:3001)
# INTERNAL_APP_URL=http://127.0.0.1:3001
# NEXT_PUBLIC_APP_URL=http://localhost:3001

# Optional: automated tenant bootstrap (POST /api/platform/bootstrap-tenant). Use a long random secret.
# PLATFORM_BOOTSTRAP_SECRET=

# ---------------------------------------------------------------------------
# Twilio Voice (inbound PSTN → /api/webhooks/twilio/voice)
# ---------------------------------------------------------------------------
# Auth token from Twilio Console — validates X-Twilio-Signature on webhooks.
# TWILIO_AUTH_TOKEN=

# Twilio <Gather> speech language (BCP-47). Default ur-PK; try en-US or en-IN if recognition fails.
# TWILIO_GATHER_LANGUAGE=ur-PK

# HMAC secret for short-lived TTS Play URLs (optional if SESSION_SECRET is ≥16 chars).
# TWILIO_TTS_PLAY_SECRET=
